# ==========================================================
# BilimAI - Muhit o'zgaruvchilari (Environment Variables)
# ----------------------------------------------------------
# Bu faylni nusxalab ".env" deb nomlang va kalitlarni qo'ying.
# .env faylini HECH QACHON GitHub'ga yuklamang!
# ==========================================================

# --- AI provayder tanlovi ---
# "gemini" (bepul, rasm bilan ishlaydi - TAVSIYA) yoki "groq" (juda tez, bepul)
AI_PROVIDER=gemini

# --- Google Gemini (https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=
# 2026-yilgi ishlaydigan modellar: gemini-2.5-flash-lite (ENG TEZ), gemini-2.5-flash, gemini-2.5-pro
# (gemini-1.5-flash va gemini-2.0-flash O'CHIRILGAN, ishlatmang!)
GEMINI_MODEL=gemini-2.5-flash-lite
# Asosiy model ishlamasa avtomatik sinaladigan zaxira modellar (vergul bilan):
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.5-pro

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram bot (https://t.me/BotFather) ---
TELEGRAM_BOT_TOKEN=8921153475:AAF4Qc425t7nSM2p_xgV_ksX1xOfJ5eUIKU

# --- Admin / Pullik obuna sozlamalari ---
# Bot egasi (admin) username - @ belgisisiz. Bu odam HAMMA funksiyadan bepul foydalanadi
# va boshqalarga premium (pullik obuna) bera oladi.
ADMIN_USERNAME=ravshanovichch
# Admin Telegram raqamli ID (ixtiyoriy, lekin tavsiya etiladi - ishonchliroq).
# Bilmasangiz bo'sh qoldiring. ID ni bilish uchun @userinfobot ga yozing.
ADMIN_ID=

# --- Instagram (reklama / obuna menyusi) ---
INSTAGRAM_HANDLE=orinboyev_ai

# --- Web server porti (Railway/Render buni avtomatik beradi) ---
PORT=8000

# --- Webhook (Render, Koyeb kabi BEPUL hostinglar uchun) ---
# Ilovangiz internetdagi ochiq manzili. Render bergan URL'ni qo'ying.
# Masalan: https://bilimai.onrender.com
# Bo'sh qoldirsangiz, bot webhook orqali ishlamaydi (mahalliy uchun polling: python bot.py).
WEBHOOK_URL=https://bilimai.onrender.com

# --- Website URL (Bot menyu'da ko'rsatiladi) ---
# BilimAI landing page URL
WEBSITE_URL=https://3000-itd3go7h80ar54clvhs38-c6f49f03.us3.manus.computer
